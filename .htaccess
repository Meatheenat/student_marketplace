# ======================================================================
# 🛡️ BNCC MARKETPLACE - ULTIMATE TITAN .htaccess (PRO EDITION)
# ======================================================================

# ----------------------------------------------------------------------
# 1. SECURITY & ACCESS CONTROL (ความปลอดภัยระดับสูงสุด)
# ----------------------------------------------------------------------
# ปิดไม่ให้คนพิมพ์ชื่อโฟลเดอร์แล้วเห็นรายชื่อไฟล์ข้างใน (Directory Browsing)
Options -Indexes

# 🚨 ไฮไลท์: บล็อกการเข้าถึงไฟล์ซ่อน (เช่น .env, .git, .htaccess) และไฟล์ระบบ
<FilesMatch "^\.|\.(env|ini|log|sh|inc|bak)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# บล็อกการเข้าถึงไฟล์เชื่อมต่อ DB และ Functions โดยตรง
<FilesMatch "^(database\.php|functions\.php|config\.php)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ----------------------------------------------------------------------
# 2. SECURITY HEADERS (เกราะป้องกันแฮกเกอร์ฝั่งเบราว์เซอร์)
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    # ป้องกัน Clickjacking (ห้ามคนเอาเว็บเราไปแปะใน iframe ซ้อนเว็บอื่น)
    Header set X-Frame-Options "SAMEORIGIN"
    # เปิดใช้งานตัวกรอง XSS ของเบราว์เซอร์
    Header set X-XSS-Protection "1; mode=block"
    # ป้องกันเบราว์เซอร์เดาประเภทไฟล์ (MIME-type sniffing)
    Header set X-Content-Type-Options "nosniff"
    # ไม่ส่งข้อมูล Referrer กลับไปหาเว็บอื่นถ้าไม่ได้ใช้ HTTPS
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ----------------------------------------------------------------------
# 3. URL REWRITE & CLEAN URL (ซ่อนนามสกุล .php ให้ดูโปร)
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # 🚀 บังคับใช้ HTTPS เสมอ (ถ้าเซิร์ฟเวอร์พี่มี SSL แล้ว ให้เอาเครื่องหมาย # ออก 2 บรรทัดล่าง)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ซ่อนนามสกุล .php (เช่น เข้าเว็บ.com/about แทน about.php)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.*)$ $1.php [NC,L]
</IfModule>

# ----------------------------------------------------------------------
# 4. PERFORMANCE & COMPRESSION (บีบอัดให้เว็บโหลดไวจัดๆ)
# ----------------------------------------------------------------------
# ตั้งค่าภาษาเริ่มต้น
AddDefaultCharset UTF-8

# บีบอัดไฟล์ (Gzip/Deflate)
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ----------------------------------------------------------------------
# 5. BROWSER CACHING (แคชไฟล์รูปลดภาระเซิร์ฟเวอร์)
# ----------------------------------------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    
    # แคชไฟล์รูปภาพ (เบราว์เซอร์จะจำไว้ 1 เดือน ไม่ต้องโหลดซ้ำ)
    ExpiresByType image/jpg "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    
    # แคช CSS/JS (1 สัปดาห์)
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    
    # แคชไอคอนและฟอนต์ (1 ปี)
    ExpiresByType image/x-icon "access plus 1 year"
    ExpiresByType application/x-font-woff "access plus 1 year"
</IfModule>

# ----------------------------------------------------------------------
# 6. CUSTOM ERROR PAGES (หน้าแจ้งเตือนเวลาคนเข้าลิงก์ผิด)
# ----------------------------------------------------------------------
# สร้างไฟล์ 404.php สวยๆ มารองรับ แล้วเอาเครื่องหมาย # ออกเพื่อใช้งานได้เลย
 ErrorDocument 403 /student_marketplace/pages/403.php
 ErrorDocument 404 /student_marketplace/pages/404.php