# ======================================================================
# 🛡️ BNCC MARKETPLACE - ULTIMATE TITAN .htaccess (PRO EDITION)
# ======================================================================

# ----------------------------------------------------------------------
# 1. SECURITY & ACCESS CONTROL (ความปลอดภัยระดับสูงสุด)
# ----------------------------------------------------------------------
# ปิดไม่ให้คนพิมพ์ชื่อโฟลเดอร์แล้วเห็นรายชื่อไฟล์ข้างใน (Directory Browsing)
Options -Indexes

# 🚨 ไฮไลท์: บล็อกการเข้าถึงไฟล์ซ่อน (เช่น .env, .git, .htaccess) และไฟล์ระบบ
# อัปเดตใช้ Require all denied สำหรับ Apache 2.4+
<FilesMatch "^\.|\.(env|ini|log|sh|inc|bak)$">
    Require all denied
</FilesMatch>

# บล็อกการเข้าถึงไฟล์เชื่อมต่อ DB และ Functions โดยตรง (เอา register.php ออกแล้ว!)
<FilesMatch "^(database\.php|functions\.php|config\.php)$">
    Require all denied
</FilesMatch>

# ----------------------------------------------------------------------
# 2. SECURITY HEADERS (เกราะป้องกันแฮกเกอร์ฝั่งเบราว์เซอร์)
# ----------------------------------------------------------------------
<IfModule mod_headers.c>
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ----------------------------------------------------------------------
# 3. URL REWRITE & CLEAN URL (ซ่อนนามสกุล .php ให้ดูโปร)
# ----------------------------------------------------------------------
<IfModule mod_rewrite.c>
    RewriteEngine On

    # 🎯 สเต็ป 1: ดักจับถ้าคนพิมพ์ไฟล์ .php มั่วๆ แล้วไม่มีอยู่จริง ให้บังคับโชว์ 404
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_URI} \.php$
    RewriteRule .* - [R=404,L]

    # 🎯 สเต็ป 2: บังคับลบ .php ออกจากเบราว์เซอร์ (ใครพิมพ์ login.php ให้เด้งเปลี่ยนเป็น login)
    RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /+(.*)\.php($|\ |\?) [NC]
    RewriteRule ^ /%1 [R=308,L]

    # 🎯 สเต็ป 3: ซ่อนนามสกุล .php (เวลาคนเข้าเว็บแบบไม่มี .php ให้ระบบแอบดึงไฟล์จริงมาแสดง)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^(.*)$ $1.php [L]
</IfModule>

# ----------------------------------------------------------------------
# 4. PERFORMANCE & COMPRESSION (บีบอัดให้เว็บโหลดไวจัดๆ)
# ----------------------------------------------------------------------
AddDefaultCharset UTF-8

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/xml text/css
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript application/x-javascript application/json
    AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# ----------------------------------------------------------------------
# 6. CUSTOM ERROR PAGES (หน้าแจ้งเตือนเวลาคนเข้าลิงก์ผิด)
# ----------------------------------------------------------------------
ErrorDocument 403 https://hosting.bncc.ac.th/s673190104/student_marketplace/pages/403.php
ErrorDocument 404 https://hosting.bncc.ac.th/s673190104/student_marketplace/pages/404.php
